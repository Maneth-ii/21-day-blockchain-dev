		"devdoc": {
			"details": "Demonstrates state machines, role-based access, and pull payments.",
			"kind": "dev",
			"methods": {
				"constructor": {
					"params": {
						"_arbiter": "Neutral third party who resolves disputes",
						"_arbiterFeePercent": "Percentage (0–10) arbiter earns if dispute occurs",
						"_durationDays": "How many days buyer has to confirm delivery",
						"_price": "Exact ETH amount (in wei) buyer must deposit",
						"_seller": "Address that will receive payment on delivery"
					}
				},
				"resolveDispute(bool)": {
					"params": {
						"favorSeller": "true = seller wins, false = buyer gets refund Arbiter always earns their fee (taken from total balance)."
					}
				}
			},
			"title": "Escrow",
			"version": 1
		},
		"userdoc": {
			"kind": "user",
			"methods": {
				"claimRefund()": {
					"notice": "Buyer can reclaim funds ONLY after the deadline passes.         Prevents abuse: buyer can't instantly refund themselves."
				},
				"confirmDelivery()": {
					"notice": "Buyer confirms they received the goods/service. Releases funds to seller."
				},
				"fund()": {
					"notice": "Buyer funds the escrow. Must send exactly `price` wei."
				},
				"raiseDispute()": {
					"notice": "Either buyer or seller can raise a dispute.         Hands control to the arbiter."
				},
				"resolveDispute(bool)": {
					"notice": "Arbiter resolves dispute. Decides who gets the funds."
				}
			},
			"notice": "A trustless escrow contract for peer-to-peer transactions.         Buyer deposits ETH → Seller delivers → Buyer confirms → Funds released.         If disputed, arbiter resolves.",
			"version": 1
		}
